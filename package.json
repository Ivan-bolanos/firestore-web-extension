{
  "name": "firestore-web-extension",
  "version": "1.0.0",
  "description": "A web extension to view Firestore documents based on Firebase Console URL",
  "main": "src/popup.js",
  "scripts": {
    "build": "webpack --config webpack.config.js --mode production",
    "build:clean": "rm -rf dist && npm run build",
    "dev": "webpack --mode development --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "prerelease": "npm test && npm run build:clean",
    "release": "./scripts/prepare-release.sh",
    "package": "cd dist && zip -r ../extension.zip . && cd .."
  },
  "author": "Ivan Bolaños",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.6",
    "@babel/preset-env": "^7.26.0",
    "babel-loader": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^9.16.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.4.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {},
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Edge versions"
  ]
}
